{
  "name": "audio",
  "version": "2.3.0",
  "description": "Audio loading, playback, analysis and editing",
  "type": "module",
  "main": "audio.js",
  "exports": {
    ".": {
      "browser": "./dist/audio.js",
      "default": "./audio.js"
    },
    "./core": "./core.js",
    "./plan": "./plan.js",
    "./stats": "./stats.js",
    "./cache": "./cache.js",
    "./worker": {
      "types": "./worker.d.ts",
      "default": "./worker.js"
    },
    "./worker-host": "./worker-host.js",
    "./worker-worklet": "./worker-worklet.js",
    "./fn/*": "./fn/*"
  },
  "types": "./audio.d.ts",
  "bin": "./bin/cli.js",
  "license": "MIT",
  "repository": "audiojs/audio",
  "files": [
    "core.js",
    "audio.js",
    "audio.d.ts",
    "plan.js",
    "stats.js",
    "cache.js",
    "worker.js",
    "worker-host.js",
    "worker-worklet.js",
    "worker.d.ts",
    "fn/",
    "bin/",
    "dist/"
  ],
  "keywords": [
    "audiojs",
    "audio",
    "dsp",
    "pcm"
  ],
  "scripts": {
    "build": "node .esbuild.js",
    "test": "node test/index.js",
    "test:cli": "TST_PARALLEL=3 node test/cli.js",
    "test:fixes": "node test/fix-plan.js && node test/fix-core.js && node test/fix-meta.js && node test/fix-worker.js",
    "test:browser": "node test/browser.js",
    "test:all": "CI=1 npm test && CI=1 npm run test:fixes && CI=1 npm run test:cli && npm run test:browser",
    "version": "node -p \"var s=require('fs'),v=require('./package.json').version;s.writeFileSync('core.js',s.readFileSync('core.js','utf8').replace(/audio\\.version = '[^']+'/,'audio.version = \\''+v+'\\''));''\" && git add core.js",
    "prepublishOnly": "npm run version && npm run build && npm run test:all",
    "serve": "node test/serve.js",
    "demo": "vhs player.tape"
  },
  "dependencies": {
    "@audio/beat": "^2.0.0",
    "@audio/decode": "^3.11.0",
    "@audio/decode-flac": "^1.1.0",
    "@audio/decode-mp3": "^1.1.0",
    "@audio/decode-wav": "^1.2.0",
    "@audio/encode": "^1.6.0",
    "@audio/encode-flac": "^1.1.0",
    "@audio/encode-mp3": "^1.1.0",
    "@audio/encode-wav": "^1.1.0",
    "@audio/eq": "^1.0.0",
    "@audio/filter": "^3.0.0",
    "@audio/mic": "^1.1.0",
    "@audio/mir": "^1.0.0",
    "@audio/note": "^1.0.0",
    "@audio/pitch": "^2.0.0",
    "@audio/speaker": "^2.3.1",
    "@audio/stretch": "^2.0.0",
    "@audio/vocals": "^1.0.1",
    "@audio/weighting": "^1.0.0",
    "@audio/window": "^1.0.0",
    "a-weighting": "^2.0.1",
    "audio-type": "^2.4.1",
    "fourier-transform": "^2.2.0",
    "parse-duration": "^2.1.6",
    "pcm-convert": "^3.1.1"
  },
  "devDependencies": {
    "@audio/denoise-debreath": "^0.1.1",
    "@audio/denoise-declick": "^0.1.1",
    "@audio/denoise-declip": "^0.1.1",
    "@audio/denoise-decrackle": "^0.1.1",
    "@audio/denoise-dehum": "^0.1.0",
    "@audio/denoise-deplosive": "^0.1.1",
    "@audio/denoise-dereverb": "^0.1.1",
    "@audio/denoise-dewind": "^0.1.1",
    "@audio/denoise-gate": "^0.1.1",
    "@audio/denoise-omlsa": "^0.1.1",
    "@audio/denoise-spectral": "^0.1.1",
    "@audio/denoise-wiener": "^0.1.1",
    "@audio/dynamics-compand": "^0.1.1",
    "@audio/dynamics-compressor": "^0.1.0",
    "@audio/dynamics-deesser": "^0.1.0",
    "@audio/dynamics-ducker": "^0.1.1",
    "@audio/dynamics-expander": "^0.1.1",
    "@audio/dynamics-gate": "^0.1.0",
    "@audio/dynamics-leveler": "^0.1.1",
    "@audio/dynamics-limiter": "^0.1.0",
    "@audio/dynamics-softclip": "^0.1.0",
    "@audio/dynamics-transient-shaper": "^0.1.1",
    "@audio/effect-autowah": "^1.1.0",
    "@audio/effect-bitcrusher": "^1.1.0",
    "@audio/effect-chorus": "^1.1.0",
    "@audio/effect-distortion": "^1.1.0",
    "@audio/effect-exciter": "^1.1.0",
    "@audio/effect-flanger": "^1.1.0",
    "@audio/effect-freqshift": "^1.1.0",
    "@audio/effect-graindelay": "^1.1.0",
    "@audio/effect-lofi": "^1.1.0",
    "@audio/effect-multitap": "^1.1.0",
    "@audio/effect-noiseshaper": "^1.1.0",
    "@audio/effect-phaser": "^1.1.0",
    "@audio/effect-pingpong": "^1.1.0",
    "@audio/effect-ringmod": "^1.1.0",
    "@audio/effect-sbr": "^1.1.0",
    "@audio/effect-slew": "^1.1.0",
    "@audio/effect-stutter": "^1.1.0",
    "@audio/effect-subbass": "^1.1.0",
    "@audio/effect-tremolo": "^1.1.0",
    "@audio/effect-vibrato": "^1.1.0",
    "@audio/effect-wah": "^1.1.0",
    "@audio/reverb-freeverb": "^1.0.0",
    "@audio/saturate-tube": "^1.0.0",
    "audio-lena": "^3.0.0",
    "esbuild": "^0.28.0",
    "playwright": "^1.59.1",
    "tst": "^9.4.0"
  }
}
