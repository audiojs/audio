{
  "name": "audio",
  "version": "2.0.0",
  "description": "Audio loading, editing, and rendering for JavaScript",
  "type": "module",
  "main": "audio.js",
  "exports": {
    ".": "./audio.js",
    "./core": "./core.js",
    "./op/*": "./op/*",
    "./stat/*": "./stat/*",
    "./fn/*": "./fn/*"
  },
  "types": "./audio.d.ts",
  "bin": "./bin/cli.js",
  "license": "MIT",
  "repository": "audiojs/audio",
  "keywords": [
    "audiojs",
    "audio",
    "dsp",
    "pcm"
  ],
  "scripts": {
    "test": "node test/index.js && node test/cli.js",
    "test:browser": "node test/serve.js"
  },
  "dependencies": {
    "audio-decode": "^3.6.0",
    "audio-filter": "^2.1.0",
    "audio-speaker": "^2.1.0",
    "audio-type": "^2.0.0",
    "encode-audio": "^1.2.0",
    "parse-duration": "^2.1.5",
    "pcm-convert": "^3.1.0"
  },
  "devDependencies": {
    "audio-lena": "^3.0.0",
    "tst": "^9.4.0"
  }
}
