{
  "name": "audio",
  "version": "2.0.0",
  "description": "Indexed, paged audio document with immutable source and declarative ops",
  "type": "module",
  "main": "src/index.js",
  "exports": "./src/index.js",
  "license": "MIT",
  "repository": "audiojs/audio",
  "keywords": [
    "audiojs",
    "audio",
    "dsp",
    "pcm"
  ],
  "scripts": {
    "test": "node test/index.js",
    "test:browser": "npx esbuild test/browser.js --bundle --format=esm --outfile=test/browser.bundle.js --platform=browser --external:fs/promises --external:url --external:audio-speaker && node test/serve.js"
  },
  "dependencies": {
    "audio-decode": "file:../audio-decode",
    "audio-encode": "file:../audio-encode"
  },
  "devDependencies": {
    "audio-lena": "file:../audio-lena",
    "esbuild": "^0.27.4",
    "tst": "file:../tst"
  }
}
