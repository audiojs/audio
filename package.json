    "test:batch": "node --test test/batch.test.js",
    "test:browser": "node test/browser.js",
    "test:all": "CI=1 npm test && CI=1 npm run test:fixes && CI=1 npm run test:cli && npm run test:browser",
    "version": "node -p \"var s=require('fs'),v=require('./package.json').version;s.writeFileSync('core.js',s.readFileSync('core.js','utf8').replace(/audio\\.version = '[^']+'/,'audio.version = \\''+v+'\\''));''\" && git add core.js",
    "prepublishOnly": "npm run version && npm run build && npm run test:all",
